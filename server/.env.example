# Private Plaid proxy — never commit .env

PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# Shared secret — mobile sends Authorization: Bearer <API_SHARED_SECRET>
API_SHARED_SECRET=

# Server bind (default: localhost only)
HOST=127.0.0.1
PORT=3001

# Optional: restrict CORS to your dev machine / Expo origin
# ALLOWED_ORIGIN=http://localhost:8081
